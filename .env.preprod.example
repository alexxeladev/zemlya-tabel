# ── .env.preprod (шаблон) ─────────────────────────────────────────────────────
# Скопируй в .env.preprod и заполни, ИЛИ просто запусти ./install.sh —
# он создаст .env.preprod и сгенерирует секреты (SECRET_KEY, пароль БД,
# пароль админа) автоматически, если файла ещё нет.
#
# .env.preprod в git НЕ коммитится (см. .gitignore) — там реальные секреты.

# Порт на хосте, на котором nginx отдаёт приложение. Ходить: http://<host>:<PORT>
PREPROD_HTTP_PORT=8080

# ── Postgres (внутри compose-сети, наружу не публикуется) ──
POSTGRES_USER=tabel
POSTGRES_PASSWORD=            # сгенерируется install.sh, если пусто
POSTGRES_DB=tabel

# ── Backend ──
# Хост БД = имя сервиса compose (db). Пароль ДОЛЖЕН совпадать с POSTGRES_PASSWORD.
# install.sh собирает эту строку сам из POSTGRES_* при генерации.
DATABASE_URL=postgresql+psycopg://tabel:CHANGE_ME@db:5432/tabel
SECRET_KEY=                   # сгенерируется install.sh, если пусто
ACCESS_TOKEN_EXPIRE_MINUTES=480
DEBUG=false
# Same-origin через nginx-прокси — CORS практически не нужен; на всякий случай
# укажи внешний URL препрода (или оставь дефолт).
CORS_ORIGINS=http://localhost:8080

# ── Frontend (build-time) ──
# Пусто → axios ходит на /api того же origin (nginx проксирует на backend).
# Меняй только если фронт обслуживается с другого origin, чем API.
VITE_API_URL=

# ── Первичный админ (создаётся install.sh один раз) ──
ADMIN_EMAIL=admin@zemlya-mo.ru
ADMIN_PASSWORD=               # сгенерируется install.sh, если пусто
ADMIN_FULL_NAME=Администратор
